        <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/CAAACAAACA> ;
    skos:notation "CA AA CA AA" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/CAAACAAAAA> a skos:Concept ;
    skos:prefLabel "COAL, OIL AND NATURAL GAS RESERVES "@en,
        "RISERVE DI CARBONE, DI PETROLIO E DI GAS NATURALE"@it ;
    skos:altLabel "AN.2121" ;
    skos:definition "Anthracite, bituminous and brown coal deposits; petroleum and natural gas reserves and fields."@en,
        "Depositi di antracite, di carbone bituminoso e di lignite; campi petroliferi e riserve di gas naturale."@it ;
    dct:identifier "CA AA CA AA AA" ;
    skos:broader <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/CAAACAAA> ;
    skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/codice-mef-raccordo-sec> ;
    skos:notation "CA AA CA AA AA" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/CAAACAAABA> a skos:Concept ;
    skos:prefLabel "METALLIC MINERAL RESERVES"@en,
        "RISERVE DI MINERALI METALLIFERI"@it ;
    skos:altLabel "AN.2122" ;
    skos:definition "Depositi di minerali di metalli ferrosi e non ferrosi e di metalli preziosi, che non siano siti paleontologici."@it,
        "Ferrous, non-ferrous and precious metal ore deposits, excluding paleontological sites."@en ;
    dct:identifier "CA AA CA AA BA" ;
    skos:broader <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/CAAACAAA> ;
    skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/codice-mef-raccordo-sec> ;
    skos:notation "CA AA CA AA BA" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/CAAACAAACA> a skos:Concept ;
    skos:prefLabel "NON-METALLIC MINERAL RESERVES"@en,
        "RISERVE DI MINERALI NON METALLIFERI"@it ;
    skos:altLabel "AN.2123" ;
    skos:definition "Cave di pietra, di argilla e di sabbia; depositi di minerali, di quarzo, di gesso, di altri minerali non metalliferi diversi dal carbone e dal petrolio, che non siano siti paleontologici."@it,
        "Stone quarries and clay and sand pits; mineral deposits; deposits of quartz, gypsum,other non-metallic minerals other than coal and petroleum, excluding paleontological sites."@en ;
    dct:identifier "CA AA CA AA CA" ;
    skos:broader <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/CAAACAAA> ;
    skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/codice-mef-raccordo-sec> ;
    skos:notation "CA AA CA AA CA" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/CAAADA> a skos:Concept ;
    skos:prefLabel "NON-CULTIVATED BIOLOGICAL RESOURCES "@en,
        "RISORSE BIOLOGICHE NON COLTIVATE"@it ;
    skos:altLabel "AN.213" ;
    skos:definition "Animali e piante che forniscono prodotti utilizzabili, sui quali sono esercitati diritti di proprietà, ma la cui crescita naturale e/o la cui rigenerazione non sono gestite o controllate direttamente (es. parchi protetti, zone di pesca nel territorio interno del Paese, acquacoltura)."@it,
        "Animals and plants that yield products over which ownership rights are enforced but for which natural growth and/or regeneration is not under direct control, responsibility and management (e.g., protected parks, fisheries within the territory of the country, aquaculture)"@en ;
    dct:identifier "CA AA DA" ;
    skos:broader <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/CAAA> ;
    skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/codice-mef-raccordo-sec> ;
    skos:narrower <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/CAAADAAA> ;
    skos:notation "CA AA DA" .

