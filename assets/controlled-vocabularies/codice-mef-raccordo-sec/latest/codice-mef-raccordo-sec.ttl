<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile> a adms:Asset,
        dcatapit:Dataset,
        skos:ConceptScheme ;
    rdfs:label "Controlled Vocabulary of MEF SEC 95 Codes for State Property Assets"@en,
        "Vocabolario Controllato dei Codici MEF SEC 95 relativi ai beni del Demanio"@it ;
    skos:prefLabel "Controlled Vocabulary of MEF SEC 95 Codes for State Property Assets"@en,
        "Vocabolario Controllato dei Codici MEF SEC 95 relativi ai beni del Demanio"@it ;
    rdfs:comment "Controlled Vocabulary of MEF SEC 95 Codes for State Property Assets"@en,
        "Vocabolario Controllato dei Codici MEF SEC 95 relativi ai beni del Demanio"@it ;
    owl:versionInfo "Versione 0.1"@it ;
    rdfs:isDefinedBy <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile> ;
    adms:representationTechnique <http://purl.org/adms/representationtechnique/SKOS> ;
    dcat:contactPoint <https://w3id.org/italia/data/contact-point/ISTAT-NDC> ;
    dcat:distribution <https://w3id.org/italia/real-estate/data/StateProperty/distribution/codice-mef-raccordo-sec-CSV>,
        <https://w3id.org/italia/real-estate/data/StateProperty/distribution/codice-mef-raccordo-sec-JSON-LD>,
        <https://w3id.org/italia/real-estate/data/StateProperty/distribution/codice-mef-raccordo-sec-RDF-Turtle>,
        <https://w3id.org/italia/real-estate/data/StateProperty/distribution/codice-mef-raccordo-sec-XLSX> ;
    dcat:keyword "Agenzia del Demanio"@it,
        "Classificazione SEC 95"@it,
        "Codici meccanografici MEF"@it,
        "ESA 95 classification"@en,
        "MEF mechanographic codes"@en,
        "Patrimonio pubblico"@it,
        "Public assets"@en,
        "State property Agency"@en ;
    dcat:theme <http://publications.europa.eu/resource/authority/data-theme/GOVE> ;
    dct:accrualPeriodicity <http://publications.europa.eu/resource/authority/frequency/IRREG> ;
    dct:conformsTo <https://w3id.org/italia/data/standard/SKOS> ;
    dct:creator <https://w3id.org/italia/data/public-organization/ISTAT> ;
    dct:description "Questa risorsa raccoglie un sottoinsieme dei codici meccanografici definiti dal Ministero dell’Economia e delle Finanze (MEF) nell’ambito della classificazione SEC ’95 (Sistema europeo dei conti), selezionati per rappresentare le categorie relative ai beni prodotti e non prodotti di appartenenza all'Agenzia del Demanio. La risorsa consente una descrizione univoca e standardizzata delle entità patrimoniali, come da Circolare MEF – Ragioneria Generale dello Stato n. 13 del 3 aprile 2003, e successive modifiche, e relativo allegato n.1 Tabella di corrispondenza tra poste patrimoniali nella nuova classificazione SEC '95 e relativa codifica meccanografica. "@it,
        "This resource collects a subset of the mechanographic codes defined by the Ministry of Economy and Finance (MEF) within the SEC ’95 classification (European System of Accounts), selected to represent the categories related to produced and non-produced assets under the responsibility of the State Property Agency. The resource enables a unique and standardized description of asset entities, in accordance with MEF – State General Accounting Department Circular No. 13 of 3 April 2003, as subsequently amended, and its Annex No. 1, Table of correspondence between balance sheet items in the new SEC ’95 classification and the related mechanographic coding. "@en ;
    dct:identifier "https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile" ;
    dct:issued "2026-03-02"^^xsd:date ;
    dct:language <http://publications.europa.eu/resource/authority/language/ITA> ;
    dct:modified "2026-03-02"^^xsd:date ;
    dct:publisher <https://w3id.org/italia/data/public-organization/PCM-1RSIZZ> ;
    dct:rightsHolder <https://w3id.org/italia/data/public-organization/agd> ;
    dct:title "Controlled Vocabulary of MEF SEC 95 Codes for State Property Assets"@en,
        "Vocabolario Controllato dei Codici MEF SEC 95 relativi ai beni del Demanio"@it ;
    dct:type <http://purl.org/adms/assettype/CodeList> ;
    ndc:keyConcept "Codice_MEF" ;
    skos:hasTopConcept <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/BA>,
        <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/CA>,
        <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/NA>,
        <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/ND> ;
    skos:notation "Controlled Vocabulary of MEF SEC 95 Codes for State Property Assets"@en,
        "Vocabolario Controllato dei Codici MEF SEC 95 relativi ai beni del Demanio"@it ;
    xkos:numberOfLevels "5" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/BA> a skos:Concept ;
    skos:prefLabel "ATTIVITÀ NON FINANZIARIE PRODOTTE"@it,
        "NON-FINANCIAL PRODUCTED ASSETS"@en ;
    skos:altLabel "AN.1" ;
    skos:definition "Attività non finanziarie ottenute quale prodotto dei processi di produzione. Le attività prodotte sono costituite da capitale fisso, scorte e oggetti di valore, come specificato in appresso."@it,
        "Non-financial assets that have come into existence as outputs from production processes. Produced assets consist of fixed assets, inventories and valuables, as defined below."@en ;
    dct:identifier "BA" ;
    skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/codice-mef-raccordo-sec> ;
    skos:isTopConcept "BA" ;
    skos:narrower <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/BAAA> ;
    skos:notation "BA" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/BAAA> a skos:Concept ;
    skos:prefLabel "Capitale fisso"@it,
        "Fixed assets"@en ;
    skos:altLabel "AN.11" ;
    skos:definition "Attività prodotte utilizzate ripetutamente o continuamente nei processi di produzione per più di un anno. Il capitale fisso è composto da beni materiali e beni immateriali come specificato in appresso."@it,
        "Produced assets that are used repeatedly or continuously in production processes for more than one year. Fixed assets consist of tangible and intangible fixed assets, as defined below."@en ;
    dct:identifier "BA AA" ;
    skos:broader <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/BA> ;
    skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/codice-mef-raccordo-sec> ;
    skos:narrower <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/BAAAAA>,
        <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/BAAABA> ;
    skos:notation "BA AA" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/BAAAAA> a skos:Concept ;
    skos:prefLabel "BENI MATERIALI PRODOTTI"@it,
        "TANGIBLE FIXED ASSETS"@en ;
    skos:altLabel "AN.111" ;
    skos:definition "Capitale fisso costituito da abitazioni, fabbricati non residenziali, opere permanenti destinate alla difesa nazionale, beni immobili di valore culturale, altre opere diverse delle abitazioni e dai fabbricati, diritti reali di godimento su beni altrui, impianti attrezzature e macchinari, mobili e arredi, mezzi di trasporto, armi ed armamenti militari, materiale bibliografico, equipaggiamenti e vestiari, strumenti musicali, coltivazioni ed allevamenti nonché altri beni materiali prodotti come di seguito specificati."@it,
        "Fixed assets that consist of dwellings; other buildings, permanent structures intended for national defense, immovable property of cultural value, other structures different from dwellings and buildings, rights in rem of enjoyment over property owned by others, plants, equipment and machinery, furniture and furnishings, means of transport, weapons and military armaments, bibliographic material, equipment and clothing, musical instruments, crops and livestock, as well as other produced tangible assets as specified below."@en ;
    dct:identifier "BA AA AA" ;
    skos:broader <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/BAAA> ;
    skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/codice-mef-raccordo-sec> ;
    skos:narrower <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/BAAAAAAA>,
        <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/BAAAAABA>,
        <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/BAAAAACA>,
        <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/BAAAAAEA>,
        <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/BAAAAAFA> ;
    skos:notation "BA AA AA" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/BAAAAAAA> a skos:Concept ;
    skos:prefLabel "Abitazioni"@it,
        "Dwellings"@en ;
    skos:altLabel "AN.1111" ;
    skos:definition """Buildings that are used entirely or primarily as residences, including any associated structures, such as garages, and all permanent fixtures customarily installed in residences. Houseboats, barges, mobile homes and caravans used as principal residences of households are also included, as are historic monuments identified primarily as dwellings. Costs of site clearance and preparation are also included.
Examples include residential buildings, such as one- and two-dwelling buildings and other residential buildings intended for non-transient occupancy.
Uncompleted dwellings are included to the extent that the ultimate user is deemed to have taken ownership, either because the construction is on own account or as evidenced by the existence of a contract of sale/purchase."""@en,
        """Fabbricati utilizzati interamente o principalmente come abitazioni, comprese le costruzioni annesse, come i garage, e tutti gli impianti permanenti usualmente installati nelle abitazioni. Sono incluse altresì le case galleggianti, le chiatte, le case viaggianti e i caravan utilizzati quali residenze principali delle famiglie, come pure i monumenti storici se destinati principalmente ad abitazioni. Sono inclusi anche i costi dèi lavori di sgombero del cantiere e di preparazione del terreno.
Esempi: edifici residenziali come i fabbricati a uno o due alloggi e gli altri edifici residenziali destinati ad essere occupati stabilmente.
Le abitazioni non completate sono incluse nella misura in cui si considera che l'utilizzatore finale ne è divenuto proprietario o perché sono state costruite per uso proprio o perché è stato stipulato un contratto di compravendita."""@it ;
    dct:identifier "BA AA AA AA" ;
    skos:broader <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/BAAAAA> ;
    skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/codice-mef-raccordo-sec> ;
    skos:narrower <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/BAAAAAAAAA>,
        <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/BAAAAAAABA>,
        <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/BAAAAAAAEA>,
        <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/BAAAAAAAFA> ;
    skos:notation "BA AA AA AA" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/BAAAAAAAAA> a skos:Concept ;
    skos:prefLabel "FABBRICATI CIVILI USO ABITATIVO (INCLUSI GLI ALLOGGI DI SERVIZIO)"@it,
        "RESIDENTIAL BUILDINGS (INCLUDING SERVICE HOUSING)"@en ;
    skos:definition "Edifici residenziali situati in contesti urbani o civili, destinati a nuclei familiari, comprensivi di eventuali alloggi di servizio e strutture accessorie come garage e impianti permanenti."@it,
        "Residential buildings located in urban or civil contexts, intended for family occupancy, including any service housing and ancillary structures such as garages and permanent installations."@en ;
    dct:identifier "BA AA AA AA AA" ;
    skos:broader <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/BAAAAAAA> ;
    skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/codice-mef-raccordo-sec> ;
    skos:notation "BA AA AA AA AA" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/BAAAAAAABA> a skos:Concept ;
    skos:prefLabel "FABBRICATI RURALI USO ABITATIVO"@it,
        "RURAL RESIDENTIAL BUILDINGS"@en ;
    skos:definition "Abitazioni situate in aree rurali o agricole, comprese le costruzioni annesse necessarie per la vita quotidiana, destinate a essere occupate stabilmente dalle famiglie."@it,
        "Dwellings situated in rural or agricultural areas, including annexed constructions necessary for daily life, intended for stable family occupancy."@en ;
    dct:identifier "BA AA AA AA BA" ;
    skos:broader <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/BAAAAAAA> ;
    skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/codice-mef-raccordo-sec> ;
    skos:notation "BA AA AA AA BA" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/BAAAAAAAEA> a skos:Concept ;
    skos:prefLabel "BUILDINGS MANAGED BY I.A.C.P."@en,
        "FABBRICATI GESTITI DALLO I.A.C.P."@it ;
    skos:definition "Abitazioni pubbliche o sociali gestite dall’Istituto Autonomo Case Popolari, destinate a uso residenziale stabile di famiglie con particolari requisiti sociali o economici."@it,
        "Public or social housing managed by the Autonomous Institute for Public Housing (I.A.C.P.), intended for stable residential use by families with specific social or economic requirements."@en ;
    dct:identifier "BA AA AA AA EA" ;
    skos:broader <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/BAAAAAAA> ;
    skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/codice-mef-raccordo-sec> ;
    skos:notation "BA AA AA AA EA" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/BAAAAAAAFA> a skos:Concept ;
    skos:prefLabel "BUILDINGS MANAGED BY LOCAL AUTHORITIES"@en,
        "FABBRICATI GESTITI DAGLI ENTI TERRITORIALI"@it ;
    skos:definition "Abitazioni di proprietà pubblica o sociale gestite da comuni, province o altre autorità locali, comprese le strutture accessorie e gli impianti permanenti, destinate all’uso residenziale della comunità o di specifici nuclei familiari."@it,
        "Public or social housing owned by local authorities (municipalities, provinces, or other territorial entities), including ancillary structures and permanent installations, intended for residential use by the community or specific family units."@en ;
    dct:identifier "BA AA AA AA FA" ;
    skos:broader <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/BAAAAAAA> ;
    skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/codice-mef-raccordo-sec> ;
    skos:notation "BA AA AA AA FA" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/BAAAAABA> a skos:Concept ;
    skos:prefLabel "Fabbricati non residenziali"@it,
        "Non-residential buildings"@en ;
    skos:altLabel "AN.11121" ;
    skos:definition "Buildings other than dwellings, including fixtures, facilities and equipment that are integral parts of the structures and costs of site clearance and preparation. Included are structures intended for worship—churches, charterhouses, abbeys—excluding worship-related land holdings. Also included are arsenals and facilities belonging to both the operational area and the technical-industrial area of the Defence sector. Prefabricated structures located in military areas and used as temporary housing and/or offices, workshops, and material depots. Barracks, until they are transferred to the State Property Agencies. Other buildings not yet completed are included to the extent that the final user is considered to have become the owner, either because a procurement contract has been signed or because a purchase agreement has been concluded."@en,
        "Fabbricati diversi dalle abitazioni, compresi gli impianti e le attrezzature che costituiscono parte integrante delle costruzioni e compresi i costi dei lavori di sgombero dei cantieri e di preparazione del terreno. Sono incluse opere destinate al culto, chiese, certose, abbazie escluse fondo culto. Inoltre arsenali e stabilimenti sia dell'area operativa che dell'area tecnico-industriale della Difesa. Prefabbricati situati in aree militari con destinazione di alloggi temporanei e/o di uffici, officine depositi di materiali. Caserme sino a quando non sono transitate in carico alle Agenzie del Demanio. Gli altri fabbricati non ancora completati sono inclusi nella misura in cui si considera che l'utilizzatore finale ne è divenuto proprietario o perché è stato stipulato un contratto di appalto o perché è stato stipulato un contratto di compravendita."@it ;
    dct:identifier "BA AA AA BA" ;
    skos:broader <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/BAAAAA> ;
    skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/codice-mef-raccordo-sec> ;
    skos:narrower <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/BAAAAABAAA>,
        <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/BAAAAABABA>,
        <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/BAAAAABACA>,
        <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/BAAAAABADA>,
        <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/BAAAAABAEA>,
        <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/BAAAAABAHA> ;
    skos:notation "BA AA AA BA" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/BAAAAABAAA> a skos:Concept ;
    skos:prefLabel "CIVIL BUILDINGS FOR INSTITUTIONAL PURPOSES (GOVERNMENT USE AND BARRACKS)"@en,
        "FABBRICATI CIVILI ADIBITI A FINI ISTITUZIONALI (USO GOVERNATIVO E CASERME)"@it ;
    skos:definition "Buildings used as public offices, state administrations, and barracks until transferred to the management of the State Property Agencies, including permanent installations and equipment."@en,
        "Edifici destinati a uffici pubblici, amministrazioni statali, e caserme fino al momento del trasferimento alla gestione delle Agenzie del Demanio, comprensivi di impianti e strutture permanenti."@it ;
    dct:identifier "BA AA AA BA AA" ;
    skos:broader <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/BAAAAABA> ;
    skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/codice-mef-raccordo-sec> ;
    skos:notation "BA AA AA BA AA" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/BAAAAABABA> a skos:Concept ;
    skos:prefLabel "COMMERCIAL BUILDINGS"@en,
        "FABBRICATI COMMERCIALI"@it ;
    skos:definition "Buildings used for commercial activities, such as shops, service centers, and private offices, including permanent equipment necessary for operation."@en,
        "Edifici adibiti ad attività commerciali, come negozi, centri servizi e uffici privati, comprensivi delle attrezzature permanenti necessarie per il funzionamento."@it ;
    dct:identifier "BA AA AA BA BA" ;
    skos:broader <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/BAAAAABA> ;
    skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/codice-mef-raccordo-sec> ;
    skos:notation "BA AA AA BA BA" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/BAAAAABACA> a skos:Concept ;
    skos:prefLabel "FABBRICATI RURALI"@it,
        "RURAL BUILDINGS"@en ;
    skos:definition "Costruzioni in aree agricole o rurali utilizzate per attività produttive diverse dall’abitazione, come stalle, magazzini agricoli e depositi di materiali."@it,
        "Structures in agricultural or rural areas used for productive activities other than housing, such as stables, agricultural warehouses, and material storage facilities."@en ;
    dct:identifier "BA AA AA BA CA" ;
    skos:broader <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/BAAAAABA> ;
    skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/codice-mef-raccordo-sec> ;
    skos:notation "BA AA AA BA CA" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/BAAAAABADA> a skos:Concept ;
    skos:prefLabel "FABBRICATI INDUSTRIALI E COSTRUZIONI LEGGERE"@it,
        "INDUSTRIAL BUILDINGS AND LIGHT CONSTRUCTIONS"@en ;
    skos:definition "Industrial plants, workshops, material depots, and prefabricated structures, including those located in military areas intended for offices or temporary housing."@en,
        "Stabilimenti industriali, officine, depositi di materiali e prefabbricati, inclusi quelli situati in aree militari destinati a uffici o alloggi temporanei."@it ;
    dct:identifier "BA AA AA BA DA" ;
    skos:broader <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/BAAAAABA> ;
    skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/codice-mef-raccordo-sec> ;
    skos:notation "BA AA AA BA DA" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/BAAAAABAEA> a skos:Concept ;
    skos:prefLabel "OPERE DESTINATE AL CULTO"@it,
        "RELIGIOUS BUILDINGS"@en ;
    skos:definition "Edifici religiosi come chiese, certose e abbazie (escluso il fondo culto), comprese le strutture annesse e gli impianti permanenti."@it,
        "Religious buildings such as churches, charterhouses, and abbeys (excluding worship-related land), including annexed structures and permanent installations."@en ;
    dct:identifier "BA AA AA BA EA" ;
    skos:broader <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/BAAAAABA> ;
    skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/codice-mef-raccordo-sec> ;
    skos:notation "BA AA AA BA EA" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/BAAAAABAHA> a skos:Concept ;
    skos:prefLabel "ALTRO"@it,
        "OTHER"@en ;
    skos:definition "Altri fabbricati non completati o con destinazioni particolari non ricomprese nelle categorie precedenti, inclusi quelli in costruzione o acquisiti tramite appalto o contratto di compravendita."@it,
        "Other incomplete buildings or buildings with specific purposes not included in the previous categories, including those under construction or acquired through procurement or purchase agreements."@en ;
    dct:identifier "BA AA AA BA HA" ;
    skos:broader <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/BAAAAABA> ;
    skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/codice-mef-raccordo-sec> ;
    skos:notation "BA AA AA BA HA" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/BAAAAACA> a skos:Concept ;
    skos:prefLabel "Beni immobili di valore culturale"@it,
        "Cultural real estate assets"@en ;
    skos:definition "Buildings of artistic, historical, archaeological or paleontological interest, or which, due to their association with political or military history, literature, art, or culture in general, have been recognized as being of particularly significant interest, as well as restoration works (to be capitalized) aimed at maintaining their material integrity and ensuring the preservation and protection of their cultural value."@en,
        "Fabbricati che presentano interesse artistico, storico, archeologico, paleontologico o che, a causa del loro riferimento con la storia politica, militare, della letteratura, dell'arte e della cultura in genere, siano stati riconosciuti di interesse particolarmente importante, nonché le opere di restauro (da capitalizzarsi) volte a mantenerne l'integrità materiale e ad assicurare la conservazione e la protezione dei loro valori culturali."@it ;
    dct:identifier "BA AA AA CA" ;
    skos:broader <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/BAAAAA> ;
    skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/codice-mef-raccordo-sec> ;
    skos:narrower <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/BAAAAACABA>,
        <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/BAAAAACACA> ;
    skos:notation "BA AA AA CA" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/BAAAAACABA> a skos:Concept ;
    skos:prefLabel "ARTISTIC ASSETS"@en,
        "BENI ARTISTICI"@it ;
    skos:definition "Buildings recognized as being of particular interest for their artistic, historical, literary, or cultural value, including restoration works aimed at maintaining their material integrity and ensuring the preservation and protection of their cultural significance."@en,
        "Fabbricati riconosciuti di particolare interesse per il loro valore artistico, storico, letterario o culturale, comprendendo anche opere di restauro finalizzate a mantenere l’integrità materiale e la conservazione dei loro valori culturali."@it ;
    dct:identifier "BA AA AA CA BA" ;
    skos:broader <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/BAAAAACA> ;
    skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/codice-mef-raccordo-sec> ;
    skos:notation "BA AA AA CA BA" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/BAAAAACACA> a skos:Concept ;
    skos:prefLabel "ARCHAEOLOGICAL ASSETS"@en,
        "BENI ARCHEOLOGICI"@it ;
    skos:definition "Buildings or structures of archaeological or paleontological relevance, including sites documenting historical periods and past cultures, with restoration interventions intended to preserve and protect the assets."@en,
        "Fabbricati o strutture con rilevanza archeologica o paleontologica, inclusi siti che documentano periodi storici e culture passate, comprendendo interventi di restauro per la conservazione e protezione dei beni."@it ;
    dct:identifier "BA AA AA CA CA" ;
    skos:broader <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/BAAAAACA> ;
    skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/codice-mef-raccordo-sec> ;
    skos:notation "BA AA AA CA CA" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/BAAAAAEA> a skos:Concept ;
    skos:prefLabel "Altre opere"@it,
        "Other structures"@en ;
    skos:altLabel "AN.11122" ;
    skos:definition """Opere diverse dai fabbricati, compresi i costi di costruzione di strade, di posa di fognature e dei lavori di sgombero del cantiere e di preparazione del terreno diversi da quelli per fabbricati.
Si comprendono in particolare:
Vie di comunicazione: strade, autostrade, idrovie, valichi, ponti, funivie, ecc.;
Strutture e infrastrutture idrauliche: ovvero beni volti alla regolamentazione dei corsi d'acqua ed al suo corretto deflusso (dighe, argini, sistemazione corsi d'acqua, canali di irrigazione, acquedotti, fognature, ecc.);
Strade ferrate e relativi materiali di esercizio: infrastrutture, gestite direttamente o affidate a terzi in concessione governativa, di diversi punti mediante sistemi ferrovari: ferrovie, binari, materiale rotabile, ecc.;
Impianti sportivi: impianti adibiti ad attività sportive (campi di calcio, stadi, campi di tennis, palestre ginnastiche, piscine pubbliche ed altri impianti di cui lo Stato è proprietario);
A parte si comprendono infine le opere in corso di costruzione, che sono incluse qualora si considera che l'utilizzatore finale ne è diventato proprietario o perché è stato stipulato un contratto di appalto, le opere di manutenzione straordinaria e le opere per la sistemazione del suolo (ovvero interventi per dare un opportuno assetto al territorio, come bonifiche, recinzioni aree protette, rimboschimenti, ecc.)."""@it,
        """Structures other than buildings, including the cost of the streets, sewers and site clearance and preparation other than for buildings.
These include in particular:
Transportation routes: roads, motorways, waterways, passes, bridges, cableways, etc.;
Hydraulic structures and infrastructures: assets intended for regulating watercourses and ensuring their proper flow (dams, embankments, river-training works, irrigation canals, aqueducts, sewer systems, etc.);
Railways and related operating equipment: infrastructures—managed directly or assigned to third parties under government concession—connecting various points by means of rail systems: railways, tracks, rolling stock, etc.;
Sports facilities: facilities used for sporting activities (football fields, stadiums, tennis courts, gymnasiums, public swimming pools, and other facilities owned by the State);
Also included, separately, are structures under construction, which are accounted for when the final user is considered to have become the owner, either because a procurement contract has been concluded, as well as extraordinary maintenance works and land improvement works (i.e., interventions aimed at giving the territory an appropriate structure, such as land reclamation, protected area fencing, reforestation, etc.)."""@en ;
    dct:identifier "BA AA AA EA" ;
    skos:broader <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/BAAAAA> ;
    skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/codice-mef-raccordo-sec> ;
    skos:narrower <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/BAAAAAEAEA> ;
    skos:notation "BA AA AA EA" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/BAAAAAEAEA> a skos:Concept ;
    skos:prefLabel "IMPIANTI SPORTIVI"@it,
        "SPORT FACILITIES"@en ;
    skos:definition "Structures intended for sporting activities, including gyms, stadiums, playing fields, public swimming pools, and other state-owned facilities, including permanent installations necessary for their operation and ancillary works."@en,
        "Strutture destinate ad attività sportive, comprese palestre, stadi, campi da gioco, piscine pubbliche e altri impianti di proprietà dello Stato, inclusi gli impianti permanenti necessari al loro funzionamento e le opere accessorie."@it ;
    dct:identifier "BA AA AA EA EA" ;
    skos:broader <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/BAAAAAEA> ;
    skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/codice-mef-raccordo-sec> ;
    skos:notation "BA AA AA EA EA" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/BAAAAAFA> a skos:Concept ;
    skos:prefLabel "Diritti reali di godimento sui beni altrui"@it,
        "Rights of enjoyment over property owned by others"@en ;
    skos:definition "Diritti che attribuiscono al titolare (Stato) una signoria limitata su beni di terzi."@it,
        "Rights that grant the holder (the State) a limited control or authority over property owned by third parties."@en ;
    dct:identifier "BA AA AA FA" ;
    skos:broader <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/BAAAAA> ;
    skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/codice-mef-raccordo-sec> ;
    skos:narrower <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/BAAAAAFAAA> ;
    skos:notation "BA AA AA FA" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/BAAAAAFAAA> a skos:Concept ;
    skos:prefLabel "DIRITTI REALI DI GODIMENTO SU BENI ALTRUI"@it,
        "RIGHTS OF ENJOYMENT OVER PROPERTY OWNED BY OTHERS"@en ;
    skos:definition "Diritti che attribuiscono al titolare (Stato) una signoria limitata su beni di terzi."@it,
        "Rights that grant the holder (the State) a limited control or authority over property owned by third parties."@en ;
    dct:identifier "BA AA AA FA AA" ;
    skos:broader <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/BAAAAAFA> ;
    skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/codice-mef-raccordo-sec> ;
    skos:notation "BA AA AA FA AA" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/BAAABA> a skos:Concept ;
    skos:prefLabel "BENI IMMATERIALI PRODOTTI"@it,
        "INTANGIBLE FIXED ASSETS"@en ;
    skos:altLabel "AN.112" ;
    skos:definition "Capitale fisso costituito da: prospezioni minerarie, software, originali di opere artistiche, letterarie o di intrattenimento o altri beni immateriali prodotti, come specificato in appresso, che si intende utilizzare per più di un anno."@it,
        "Fixed assets that consist of: mineral exploration, computer software, entertainment, literary or artistic originals and other intangible fixed assets, as defined below, intended to be used for more than one year."@en ;
    dct:identifier "BA AA BA" ;
    skos:broader <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/BAAA> ;
    skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/codice-mef-raccordo-sec> ;
    skos:narrower <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/BAAABAAA> ;
    skos:notation "BA AA BA" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/BAAABAAA> a skos:Concept ;
    skos:prefLabel "Diritti di sfruttamento"@it,
        "Exploitation rights"@en ;
    skos:definition "Diritti sui beni per ricavare il maggior utile possibile."@it,
        "Rights over assets aimed at deriving the maximum possible benefit."@en ;
    dct:identifier "BA AA BA AA" ;
    skos:broader <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/BAAABA> ;
    skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/codice-mef-raccordo-sec> ;
    skos:narrower <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/BAAABAAAAA> ;
    skos:notation "BA AA BA AA" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/BAAABAAAAA> a skos:Concept ;
    skos:prefLabel "MINERAL EXPLORATION"@en,
        "PROSPEZIONI MINERARIE"@it ;
    skos:altLabel "AN.1121" ;
    skos:definition "Importo delle spese per la ricerca di petrolio, di gas naturale e di giacimenti non petroliferi. Tali spese comprendono i costi precedenti all'ottenimento delle autorizzazioni, i costi per il rilascio delle autorizzazioni e i costi di acquisizione, i costi di valutazione e i costi delle effettive trivellazioni esplorative e di perforazione, come pure i costi di rilievi aerei o altre indagini, i costi di trasporto, ecc., sostenuti per rendere possibile l'esecuzione delle prospezioni."@it,
        "The value of expenditures on exploration for petroleum and natural gas and for non-petroleum deposits. These expenditures include prelicence costs, licence and acquisition costs, appraisal costs and the costs of actual test drilling and boring, as well as the costs of aerial and other surveys, transportation costs, etc., incurred to make it possible to carry out the tests."@en ;
    dct:identifier "BA AA BA AA AA" ;
    skos:broader <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/BAAABAAA> ;
    skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/codice-mef-raccordo-sec> ;
    skos:notation "BA AA BA AA AA" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/CA> a skos:Concept ;
    skos:prefLabel """ATTIVITÀ NON FINANZIARIE
NON PRODOTTE"""@it,
        "NON-FINANCIAL NON-PRODUCED ASSETS"@en ;
    skos:altLabel "AN.2" ;
    skos:definition "Attività non finanziarie che non sono ottenute quale prodotti di processi di produzione. Le attività non prodotte sono costituite da beni materiali e beni immateriali, come specificato in appresso."@it,
        "Non-financial assets that come into existence other than through processes of production. Non-produced assets consist of tangible assets and intangible assets, as defined below. "@en ;
    dct:identifier "CA" ;
    skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/codice-mef-raccordo-sec> ;
    skos:isTopConcept "CA" ;
    skos:narrower <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/CAAA> ;
    skos:notation "CA" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/CAAA> a skos:Concept ;
    skos:prefLabel "Beni materiali non prodotti"@it,
        "Tangible non-produced assets"@en ;
    skos:altLabel "AN.21" ;
    skos:definition "Attività non prodotte presenti in natura sulle quali possono essere esercitati diritti di proprietà, incluso il trasferimento di questi. Sono esclusi i beni legati all'ambiente sui quali non sono o non possono essere esercitati diritti di proprietà. I beni materiali non prodotti sono costituiti da beni del demanio naturale, terreni, giacimenti, risorse biologiche non coltivate."@it,
        "Non-produced assets that occur in nature and over which ownership may be enforced and transferred. Environmental assets over which ownership rights have not, or cannot, be enforced are excluded. Tangible non-produced assets consist of natural state-owned assets, land, subsoil assets, non-cultivated biological resources."@en ;
    dct:identifier "CA AA" ;
    skos:broader <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/CA> ;
    skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/codice-mef-raccordo-sec> ;
    skos:narrower <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/CAAAAA>,
        <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/CAAABA>,
        <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/CAAACA>,
        <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/CAAADA> ;
    skos:notation "CA AA" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/CAAAAA> a skos:Concept ;
    skos:prefLabel "BENI DEL DEMANIO NATURALE"@it,
        "NATURAL STATE-OWNED ASSETS"@en ;
    skos:definition "Beni di proprietà dello Stato costituiti dal demanio marittimo, dal demanio idrico e forestale."@it,
        "State-owned assets consisting of maritime, water, and forest public property."@en ;
    dct:identifier "CA AA AA" ;
    skos:broader <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/CAAA> ;
    skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/codice-mef-raccordo-sec> ;
    skos:narrower <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/CAAAAAAA> ;
    skos:notation "CA AA AA" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/CAAAAAAA> a skos:Concept ;
    skos:prefLabel "Beni del demanio naturale"@it,
        "Natural State-Owned Assets"@en ;
    skos:definition "Beni di proprietà dello Stato costituiti dal demanio marittimo, dal demanio idrico e forestale."@it,
        "State-owned assets consisting of maritime, water, and forest public property."@en ;
    dct:identifier "CA AA AA AA" ;
    skos:broader <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/CAAAAA> ;
    skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/codice-mef-raccordo-sec> ;
    skos:narrower <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/CAAAAAAAAA>,
        <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/CAAAAAAABA>,
        <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/CAAAAAAACA> ;
    skos:notation "CA AA AA AA" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/CAAAAAAAAA> a skos:Concept ;
    skos:prefLabel "Demanio marittimo"@it,
        "Maritime public domain"@en ;
    skos:definition "Lido del mare, spiaggia, porti, rade, lagune, foci dei fiumi, bacini d'acqua, canali utilizzabili per uso pubblico marittimo, pertinenze del demanio marittimo."@it,
        "Seashores, beaches, harbours, roadsteads, lagoons, river mouths, water basins, canals usable for public maritime purposes, and appurtenances of the maritime public domain."@en ;
    dct:identifier "CA AA AA AA AA" ;
    skos:broader <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/CAAAAAAA> ;
    skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/codice-mef-raccordo-sec> ;
    skos:notation "CA AA AA AA AA" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/CAAAAAAABA> a skos:Concept ;
    skos:prefLabel "Demanio idrico"@it,
        "Water public domain"@en ;
    skos:definition "Fiumi, laghi, torrenti, rivi, fossati, colatori, acque sotterranee, acque sorgenti, ghiacciai, porti ed approdi destinati alla navigazione interna, acquedotti e canali demaniali."@it,
        "Rivers, lakes, streams, creeks, ditches, drainage channels, groundwater, spring waters, glaciers, ports and landings intended for inland navigation, and public aqueducts and canals."@en ;
    dct:identifier "CA AA AA AA BA" ;
    skos:broader <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/CAAAAAAA> ;
    skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/codice-mef-raccordo-sec> ;
    skos:notation "CA AA AA AA BA" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/CAAAAAAACA> a skos:Concept ;
    skos:prefLabel "Foreste"@it,
        "Forests"@en ;
    skos:definition "National forest heritage."@en,
        "Patrimonio boschivo nazionale."@it ;
    dct:identifier "CA AA AA AA CA" ;
    skos:broader <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/CAAAAAAA> ;
    skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/codice-mef-raccordo-sec> ;
    skos:notation "CA AA AA AA CA" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/CAAABA> a skos:Concept ;
    skos:prefLabel "LAND"@en,
        "TERRENI"@it ;
    skos:altLabel "AN.211" ;
    skos:definition "Terreni, compresa la copertura del suolo, nonché le relative acque di superficie, su cui sono esercitati i diritti di proprietà. Sono esclusi i fabbricati o le altre opere costruite su di essi o che li attraversano, le coltivazioni, gli alberi e gli animali. I terreni sono costituiti da aree edificabili, terreni sottostanti a fabbricati e ad altre opere, terreni coltivati, parchi con relative acque di superficie, aree archeologiche e terreni sottoposti a tutela, ed altri terreni con relative acque di superficie, come specificato in appresso."@it,
        "The ground, including the soil covering and any associated surface waters, over which ownership rights are enforced. Excluded are any buildings or other structures situated on it or running through it; cultivated crops, trees and animals. Land consists of building sites, land underlying buildings and structures, land under cultivation, recreational land and associated surface water, archaeological areas and protected land, and other land and associated surface water, as defined below."@en ;
    dct:identifier "CA AA BA" ;
    skos:broader <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/CAAA> ;
    skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/codice-mef-raccordo-sec> ;
    skos:narrower <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/CAAABAAA> ;
    skos:notation "CA AA BA" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/CAAABAAA> a skos:Concept ;
    skos:prefLabel "Land"@en,
        "Terreni"@it ;
    skos:definition "Terreni, compresa la copertura del suolo, nonché le relative acque di superficie, su cui sono esercitati i diritti di proprietà. Sono esclusi i fabbricati o le altre opere costruite su di essi o che li attraversano, le coltivazioni, gli alberi e gli animali. I terreni sono costituiti da aree edificabili, terreni sottostanti a fabbricati e ad altre opere, terreni coltivati, parchi con relative acque di superficie, aree archeologiche e terreni sottoposti a tutela, ed altri terreni con relative acque di superficie, come specificato in appresso."@it,
        "The ground, including the soil covering and any associated surface waters, over which ownership rights are enforced. Excluded are any buildings or other structures situated on it or running through it; cultivated crops, trees and animals. Land consists of building sites, land underlying buildings and structures, land under cultivation, recreational land and associated surface water, archaeological areas and protected land, and other land and associated surface water, as defined below."@en ;
    dct:identifier "CA AA BA AA" ;
    skos:broader <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/CAAABA> ;
