<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/CAAABAAAAA> a skos:Concept ;
    skos:prefLabel "AREE EDIFICABILI"@it,
        "BUILDING AREAS"@en ;
    skos:definition "Areas for which urban development plans have been envisaged."@en,
        "Aree per le quali sono prefigurati piani urbanistici."@it ;
    dct:identifier "CA AA BA AA AA" ;
    skos:broader <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/CAAABAAA> ;
    skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/codice-mef-raccordo-sec> ;
    skos:notation "CA AA BA AA AA" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/CAAABAAABA> a skos:Concept ;
    skos:prefLabel "AREAS SUBJECT TO URBAN PLANNING RESTRICTIONS PRELIMINARY TO EXPROPRIATION"@en,
        "AREE ASSOGGETTATE A VINCOLI URBANISTICI PREORDINATI ALL'ESPROPRIO"@it ;
    skos:definition "Areas for which specific urban planning restrictions have been established."@en,
        "Aree per le quali esistono determinati vincoli urbanistici."@it ;
    dct:identifier "CA AA BA AA BA" ;
    skos:broader <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/CAAABAAA> ;
    skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/codice-mef-raccordo-sec> ;
    skos:notation "CA AA BA AA BA" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/CAAABAAACA> a skos:Concept ;
    skos:prefLabel "LAND UNDERLYING BUILDINGS AND STRUCTURES"@en,
        "TERRENI SOTTOSTANTI A FABBRICATI ED ALTRE OPERE"@it ;
    skos:altLabel "AN.2111" ;
    skos:definition "Land on which dwellings, non-residential buildings and structures are constructed or into which their foundations are dug, including yards and gardens deemed an integral part of farm and non-farm dwellings and access roads to farms."@en,
        "Terreni su cui sono costruiti fabbricati non residenziali, abitazioni ed altre opere o nei quali poggiano le fondazioni di questi, compresi i cortili ed i giardini considerati parte integrante di abitazioni rurali e non rurali e strade di accesso a fattorie."@it ;
    dct:identifier "CA AA BA AA CA" ;
    skos:broader <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/CAAABAAA> ;
    skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/codice-mef-raccordo-sec> ;
    skos:notation "CA AA BA AA CA" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/CAAABAAADA> a skos:Concept ;
    skos:prefLabel "LAND UNDER CULTIVATION"@en,
        "TERRENI COLTIVATI"@it ;
    skos:altLabel "AN.2112" ;
    skos:definition "Land on which agricultural or horticultural production is carried on for commercial or subsistence purposes, including, in principle, land under plantations, orchards and vineyards."@en,
        "Terreni sui quali viene svolta, a fini commerciali o di sussistenza, una attività di produzione agricola o orticola, compresi, in linea di principio, i terreni a frutteto, a vigneto e ad altre coltivazioni."@it ;
    dct:identifier "CA AA BA AA DA" ;
    skos:broader <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/CAAABAAA> ;
    skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/codice-mef-raccordo-sec> ;
    skos:notation "CA AA BA AA DA" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/CAAABAAAEA> a skos:Concept ;
    skos:prefLabel "PARCHI CON RELATIVE ACQUE DI SUPERFICIE"@it,
        "RECREATIONAL LAND AND ASSOCIATED SURFACE WATER "@en ;
    skos:altLabel "AN.2113" ;
    skos:definition "Parchi, giardini per uso pubblico."@it,
        "Parks and gardens for public use."@en ;
    dct:identifier "CA AA BA AA EA" ;
    skos:broader <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/CAAABAAA> ;
    skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/codice-mef-raccordo-sec> ;
    skos:notation "CA AA BA AA EA" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/CAAABAAAFA> a skos:Concept ;
    skos:prefLabel "ARCHAEOLOGICAL AREAS AND PROTECTED LAND"@en,
        "AREE ARCHEOLOGICHE E TERRENI SOTTOPOSTI A TUTELA"@it ;
    skos:definition "Areas of archaeological, historical, artistic, or environmental interest, including ancient drove roads, Roman land divisions, underground structures, tunnels, and similar features."@en,
        "Aree che rivestono interesse archeologico, storico, artistico, ambientale, ivi compresi i tratturi, le centuriazioni, le sostituzioni, le gallerie e simili."@it ;
    dct:identifier "CA AA BA AA FA" ;
    skos:broader <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/CAAABAAA> ;
    skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/codice-mef-raccordo-sec> ;
    skos:notation "CA AA BA AA FA" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/CAAABAAAGA> a skos:Concept ;
    skos:prefLabel "ALTRI TERRENI CON RELATIVE ACQUE DI SUPERFICIE"@it,
        "OTHER LAND AND ASSOCIATED SURFACE WATER"@en ;
    skos:altLabel "AN.2119" ;
    skos:definition "Land not elsewhere classified, including gardens and plots not cultivated for subsistence or commercial purposes, communal grazing land, land surrounding dwellings in excess of those yards and gardens deemed an integral part of farm and non-farm dwellings and associated surface water."@en,
        "Terreni non classificati altrove, compresi i giardini e le particelle di terreno non coltivate a scopo di sussistenza o commerciali, le superfici pubbliche adibite a pascolo, i terreni circondanti le abitazioni per la parte che eccede i cortili ed i giardini considerati parte integrante delle abitazioni rurali e non rurali e le connesse acque di superficie."@it ;
    dct:identifier "CA AA BA AA GA" ;
    skos:broader <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/CAAABAAA> ;
    skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/codice-mef-raccordo-sec> ;
    skos:notation "CA AA BA AA GA" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/CAAACA> a skos:Concept ;
    skos:prefLabel "GIACIMENTI"@it,
        "SUBSOIL ASSETS"@en ;
    skos:altLabel "AN.212" ;
    skos:definition "Proven reserves of mineral deposits located on or below the earth's surface that are economically exploitable, given current technology and relative prices. Subsoil assets consist of coal, oil and natural gas reserves, metallic mineral reserves and non-metallic mineral reserves, as defined below."@en,
        "Riserve comprovate di minerali, poste sulla superficie terrestre o al di sotto di essa, economicamente sfruttabili, considerata la tecnologia attuale ed i prezzi relativi. I giacimenti comprendono le riserve di carbone, di petrolio e di gas naturale, le riserve di minerali metalliferi e le riserve di minerali non metalliferi, come in appresso specificato."@it ;
    dct:identifier "CA AA CA" ;
    skos:broader <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/CAAA> ;
    skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/codice-mef-raccordo-sec> ;
    skos:narrower <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/CAAACAAA> ;
    skos:notation "CA AA CA" .

<https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/CAAACAAA> a skos:Concept ;
    skos:prefLabel "Giacimenti"@it,
        "Subsoil Assets"@en ;
    skos:definition "Proven reserves of mineral deposits located on or below the earth's surface that are economically exploitable, given current technology and relative prices. Subsoil assets consist of coal, oil and natural gas reserves, metallic mineral reserves and non-metallic mineral reserves, as defined below."@en,
        "Riserve comprovate di minerali, poste sulla superficie terrestre o al di sotto di essa, economicamente sfruttabili, considerata la tecnologia attuale ed i prezzi relativi. I giacimenti comprendono le riserve di carbone, di petrolio e di gas naturale, le riserve di minerali metalliferi e le riserve di minerali non metalliferi, come in appresso specificato."@it ;
    dct:identifier "CA AA CA AA" ;
    skos:broader <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/CAAACA> ;
    skos:inScheme <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/codice-mef-raccordo-sec> ;
    skos:narrower <https://w3id.org/italia/real-estate/controlled-vocabulary/StateProperty/CodiceMEFRaccordoSECImmobile/CAAACAAAAA>,
